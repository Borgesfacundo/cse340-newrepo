<div class="site-container">
  <div class="background-container">
    <img
      class="background-img"
      src="/images/site/small_check.jpg"
      alt="Background Image"
    />
    <section class="hero">
      <h2>Welcome to CSE Motors!</h2>
      <picture>
        <source
          srcset="/images/vehicles/delorean-tn.jpg"
          media="(max-width: 500px)"
        />
        <img
          class="img-hero"
          src="/images/vehicles/delorean.jpg"
          alt="Delorean Car Image"
          loading="lazy"
          width="200"
          height="102"
        />
      </picture>
      <div class="hero-info">
        <h3>DMC Delorean</h3>
        <p>3 Cup holders</p>
        <p>Superman doors</p>
        <p>Fuzzy dice!</p>
        <a href="/images/vehicles/delorean.jpg" class="btn">Own Today</a>
      </div>
    </section>

    <section class="vehicle-info">
      <div class="reviews">
        <h2>DMC Delorean Reviews</h2>
        <ul>
          <li>"So fast it's almost like traveling in time." (4/5)</li>
          <li>"Coolest ride on the road." (4/5)</li>
          <li>"I'm feeling McFly!." (5/5)</li>
          <li>"The most futuristic road of our day." (4.5/5)</li>
          <li>"80's livin and I love it!." (5/5)</li>
        </ul>
      </div>

      <div class="upgrades">
        <h2>Delorean Upgrades</h2>
        <div class="upgrade-container">
          <div class="upgrade-img">
            <img src="/images/upgrades/flux-cap.png" alt="Flux Cap" />
          </div>
          <a href="#">Flux Capacitor</a>
        </div>
        <div class="upgrade-container">
          <div class="upgrade-img">
            <img src="/images/upgrades/flame.jpg" alt="Flame decals" />
          </div>
          <a href="#">Flame Decals</a>
        </div>
        <div class="upgrade-container">
          <div class="upgrade-img">
            <img
              src="/images/upgrades/bumper_sticker.jpg"
              alt="Bumper sticker"
            />
          </div>
          <a href="#">Bumper Stickers</a>
        </div>
        <div class="upgrade-container">
          <div class="upgrade-img">
            <img src="/images/upgrades/hub-cap.jpg" alt="Hub caps" />
          </div>
          <a href="#">Hub Caps</a>
        </div>
      </div>
    </section>
  </div>
</div>
